# Azx Scrap Bot — Vite env (loaded at build/dev time, prefix VITE_)
# Copy to `.env` and adjust.

# Where the UI sends API requests. In dev, leave as /api (proxied to :8088).
# In production behind a reverse proxy, also /api. For a non-proxied setup,
# point to the absolute Go backend URL.
VITE_API_BASE_URL=/api

# App version, surfaced in the UI footer. Bump on each release.
VITE_APP_VERSION=0.1.0

# Optional: pre-fill the setup form with this token. Mirrors the
# AZX_SETUP_TOKEN env var on the Go side. Leave empty to require the
# user to paste the token from the boot banner.
VITE_SETUP_TOKEN=

# Optional: pre-fill the admin username/password in the setup form.
# Mirrors AZX_ADMIN_USERNAME / AZX_ADMIN_PASSWORD on the Go side.
# DEV CONVENIENCE ONLY. Never set these in production.
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=

