# Azx Scrap Bot — Go server config
# Copy to `.env` and adjust. Values are loaded at startup; flags/env override.

# Listen address
ADDR=:8080

# SQLite database file
DB=./store.db

# Where the buffered rotating log files are written
LOG_DIR=./logs
LOG_LEVEL=debug
LOG_MAX_SIZE=50
LOG_MAX_BACKUPS=5
LOG_COMPRESS=true

# Dev-only: serve SPA from this dir instead of the embedded one
# (set automatically by `make dev-go`)
# ASSETS_DIR=./ui/dist

# JWT HMAC secret. If set, overrides the DB-stored one. Pick any random
# 32+ char string. Changing this invalidates all existing tokens.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=
